{
  "_meta": {
    "version": "1.0",
    "created": "2026-04-12",
    "purpose": "AI 매핑 품질 검증 — 자동 채점용 기계어 스펙",
    "cross_check_status": "all_70_verified",
    "cross_check_notes": [
      "70/70 기대값이 입력 txt에 실제로 존재 확인됨",
      "부분 매치 7건: 기대값(핵심)은 txt(확장)의 substring. 양방향 substring 매치로 처리",
      "TC-05#8 근무 요일: 원래 가이드 기대값 '화·수·목·토' → txt 원문 포맷 '화요일, 수요일, 목요일, 토요일'로 수정"
    ]
  },

  "scoring_rules": {
    "match_mode": "substring_bidirectional",
    "match_mode_description": "AI 값이 기대값을 포함하거나 기대값이 AI 값을 포함하면 정답. 공백 정규화 후 비교.",
    "critical_rule": {
      "behavior": "demote_to_D",
      "description": "critical=true 필드가 하나라도 틀리면 등급을 자동 D로 강등. 점수와 무관."
    },
    "grade_thresholds": {
      "A": 90,
      "B": 75,
      "C": 50,
      "D": 0
    },
    "field_count_rule": "expected_only",
    "field_count_description": "분모 = 이 스펙에 정의된 기대값 개수 (양식 전체 빈칸 개수 아님)"
  },

